# === REQUIRED (free) ===

# Anthropic API (required for content generation)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Hugging Face (free — for RAG embeddings and reranking, no local models)
# Sign up at huggingface.co → Settings → Access Tokens
HF_TOKEN=hf_your_token_here

# Turso (free — cloud SQLite database; local libsql used for tests/dev)
# Sign up at turso.tech → Create database → Get URL + token
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ChromaDB (free — cloud vector database, falls back to local)
# Sign up at cloud.trychroma.com → Get API key
CHROMA_API_KEY=chr_your_api_key
CHROMA_TENANT=your_tenant_id
CHROMA_DATABASE=your_database_name

# Contextual AI (free $50 / 1B tokens — cross-encoder reranker for RAG)
# Sign up at contextual.ai → Get API key
CONTEXTUAL_API_KEY=key_your_api_key

# === OPTIONAL ===

# RevenueCat API (optional — use DEMO_MODE=true without it)
REVENUECAT_API_KEY=sk_your_secret_key_here
REVENUECAT_PROJECT_ID=proj_your_project_id

# GitHub (optional — for deploy, issue scanning, feedback export)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=akshan-main/revcat-agent-advocate

# Twitter/X (optional — for social engagement)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Reddit (optional — for community engagement)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Dev.to (free — for publishing articles with organic discovery)
# Get API key: dev.to/settings/extensions → DEV Community API Keys
DEVTO_API_KEY=

# AI Model (default: claude-sonnet-4-6, or claude-opus-4-6 for highest quality)
AI_MODEL=claude-sonnet-4-6

# Safety flags
DEMO_MODE=false          # true = use mock API responses for testing
DRY_RUN=true             # true = no external posts, no GitHub issues, drafts only
ALLOW_WRITES=false       # true = allow POST/PUT/DELETE to RC API (default: read-only)

# Ledger
LEDGER_HMAC_KEY=         # optional — if set, signs each ledger entry with HMAC-SHA256

# Search API (deployed URL — enables live doc search in Revel and Issue Helper)
# Deploy on Render (free) or Fly.io, then set this to the URL
SEARCH_API_URL=https://rcagent-search.onrender.com

# Site
SITE_BASE_URL=                # e.g. /revcat-agent-advocate for GitHub Pages project sites

# Paths (only used as fallback if cloud services not configured)
DB_PATH=./advocate.db
DOCS_CACHE_DIR=./.docs_cache
SITE_OUTPUT_DIR=./site_output
RUNS_DIR=./runs
