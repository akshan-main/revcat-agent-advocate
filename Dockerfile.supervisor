FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm && rm -rf /var/lib/apt/lists/*

RUN useradd -m agent
WORKDIR /home/agent/app

COPY . .
RUN pip install --no-cache-dir .

# Playwright MCP needs Chromium. Install as root, then switch to agent.
RUN npx @playwright/mcp@0.0.28 --help || true && npx playwright@1.52.0 install --with-deps chromium

USER agent

ENTRYPOINT ["revcat-advocate", "supervise"]
CMD ["--max-actions", "3"]
