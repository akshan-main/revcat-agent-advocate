FROM python:3.12-slim

# System deps: Node.js, fonts, and Chromium runtime libraries
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm fonts-unifont \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libpango-1.0-0 libcairo2 libasound2 libatspi2.0-0 libxshmfence1 libxkbcommon0 \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m agent
WORKDIR /home/agent/app

COPY --chown=agent:agent . .
RUN pip install --no-cache-dir .

# Install Playwright MCP globally so it's on the read-only filesystem at runtime.
# Set browser path so both root (build) and agent (runtime) use the same location.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
# Install MCP package globally, then use its bundled playwright to install chromium.
RUN npm install -g @playwright/mcp@0.0.28 \
    && chmod -R a+rx /usr/local/lib/node_modules/@playwright \
    && /usr/local/lib/node_modules/@playwright/mcp/node_modules/.bin/playwright install chromium \
    && chmod -R a+rx /opt/pw-browsers \
    && echo "=== Chromium install verification ===" \
    && ls -la /opt/pw-browsers/ \
    && ls -la /opt/pw-browsers/chromium-*/chrome-linux/ 2>/dev/null || ls -la /opt/pw-browsers/chromium-*/ \
    && which mcp-server-playwright \
    && echo "PLAYWRIGHT_BROWSERS_PATH=$PLAYWRIGHT_BROWSERS_PATH"

USER agent

ENTRYPOINT ["revcat-advocate", "supervise"]
CMD ["--max-actions", "3"]
