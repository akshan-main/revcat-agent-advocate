FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm fonts-unifont && rm -rf /var/lib/apt/lists/*

RUN useradd -m agent
WORKDIR /home/agent/app

COPY --chown=agent:agent . .
RUN pip install --no-cache-dir .

# Playwright MCP needs Chromium. Install deps manually (Debian Trixie
# renamed ttf-unifont/ttf-ubuntu-font-family), then install browser.
RUN npx @playwright/mcp@0.0.28 --help || true \
    && npx playwright@1.52.0 install chromium \
    && npx playwright@1.52.0 install-deps chromium 2>/dev/null || true

USER agent

ENTRYPOINT ["revcat-advocate", "supervise"]
CMD ["--max-actions", "3"]
